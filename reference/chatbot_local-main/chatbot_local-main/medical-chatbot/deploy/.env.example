# App ports
FRONTEND_PORT=8400

# Frontend build/runtime variables
# IMPORTANT: Because frontend uses Nginx proxy_pass, use internal Docker DNS URL.
VITE_BACKEND_URL=
VITE_DOCUMENT_FILE_URL_TEMPLATE=https://your-domain/api/v1/documents/{documentId}/file
VITE_MAINTENANCE_MESSAGE=

# dùng databse guideline management
DB_HOST=postgres
DB_PORT=5432
DB_NAME=db
DB_USER=postgres
DB_PASS=postgres

# Backend auth
JWT_SECRET=change_me_for_local_development

# Chat API
OPENAI_API_KEY=sk-xxx
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-large
